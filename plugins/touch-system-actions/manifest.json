{
  "id": "com.tuffex.system-actions",
  "name": "touch-system-actions",
  "version": "1.0.0",
  "author": "TalexTouch Team",
  "sdkapi": 260428,
  "category": "utilities",
  "icon": {
    "type": "file",
    "value": "assets/logo.svg"
  },
  "description": "系统高级控制：关机 / 重启 / 锁屏 / 音量 / 亮度 / 主窗口",
  "main": "index.js",
  "permissions": {
    "required": ["system.shell", "search.root-results"],
    "optional": []
  },
  "permissionReasons": {
    "system.shell": "执行系统命令完成关机、重启、锁屏、音量与亮度操作",
    "search.root-results": "将系统操作入口推送到 CoreBox 根搜索结果"
  },
  "searchProviders": [
    {
      "id": "touch-system-actions.system-actions",
      "displayName": "系统操作",
      "featureId": "system-actions",
      "kind": "system-action",
      "owner": "official-plugin",
      "mode": "push",
      "priority": "fast",
      "defaultOrder": 90,
      "permissionScopes": ["root-results"],
      "defaultState": "ask",
      "requiresUserConsent": true,
      "pushesToRootResults": true
    }
  ],
  "features": [
    {
      "id": "system-actions",
      "name": "系统操作",
      "desc": "全量系统动作入口",
      "icon": {
        "type": "file",
        "value": "assets/logo.svg"
      },
      "keywords": ["system", "sys", "系统", "关机", "重启", "锁屏", "音量", "亮度", "主窗口"],
      "push": true,
      "priority": 7,
      "acceptedInputTypes": ["text"],
      "platform": {
        "win32": true,
        "darwin": true,
        "linux": false
      },
      "commands": [
        {
          "type": "over",
          "value": ["system", "sys", "系统", "系统操作"]
        }
      ]
    }
  ]
}
