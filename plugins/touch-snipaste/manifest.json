{
  "id": "com.tuffex.snipaste",
  "name": "touch-snipaste",
  "version": "1.0.0",
  "author": "TalexTouch Team",
  "sdkapi": 260428,
  "category": "utilities",
  "icon": {
    "type": "file",
    "value": "assets/logo.svg"
  },
  "description": "Snipaste 快捷控制：截图、贴图、取色",
  "main": "index.js",
  "permissions": {
    "required": ["system.shell", "search.root-results"],
    "optional": []
  },
  "permissionReasons": {
    "system.shell": "通过 spawn 启动 Snipaste 程序执行截图、贴图等命令",
    "search.root-results": "将 Snipaste 快捷控制入口推送到 CoreBox 根搜索结果"
  },
  "searchProviders": [
    {
      "id": "touch-snipaste.snipaste-quick",
      "displayName": "Snipaste",
      "featureId": "snipaste-quick",
      "kind": "system-action",
      "owner": "official-plugin",
      "mode": "push",
      "priority": "fast",
      "defaultOrder": 94,
      "permissionScopes": ["root-results"],
      "defaultState": "ask",
      "requiresUserConsent": true,
      "pushesToRootResults": true
    }
  ],
  "features": [
    {
      "id": "snipaste-quick",
      "name": "Snipaste",
      "desc": "截图 / 贴图 / 取色",
      "icon": {
        "type": "file",
        "value": "assets/logo.svg"
      },
      "keywords": ["snipaste", "snip", "截图", "贴图", "取色"],
      "push": true,
      "priority": 8,
      "acceptedInputTypes": ["text"],
      "platform": {
        "win32": true,
        "darwin": true,
        "linux": true
      },
      "commands": [
        {
          "type": "over",
          "value": ["snipaste", "snip", "截图", "贴图", "取色", "贴图管理"]
        }
      ]
    }
  ]
}
