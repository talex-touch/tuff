{
  "id": "com.tuffex.browser-bookmarks",
  "name": "touch-browser-bookmarks",
  "version": "1.0.0",
  "author": "TalexTouch Team",
  "sdkapi": 260428,
  "category": "utilities",
  "icon": {
    "type": "file",
    "value": "assets/logo.svg"
  },
  "description": "快速链接：手动收藏、置顶链接、最近使用与快速打开",
  "main": "index.js",
  "permissions": {
    "required": ["search.root-results"],
    "optional": ["clipboard.write", "network.internet"]
  },
  "permissionReasons": {
    "search.root-results": "将收藏网址与最近访问推送到 CoreBox 根搜索结果",
    "clipboard.write": "复制网址到剪贴板",
    "network.internet": "使用默认浏览器打开收藏或最近访问网址"
  },
  "searchProviders": [
    {
      "id": "touch-browser-bookmarks.quicklinks",
      "displayName": "手动快速链接",
      "kind": "quicklink",
      "owner": "official-plugin",
      "mode": "push",
      "priority": "fast",
      "defaultOrder": 65,
      "permissionScopes": ["root-results"],
      "defaultState": "ask",
      "requiresUserConsent": true,
      "pushesToRootResults": true,
      "indexedSourceId": "quicklinks"
    }
  ],
  "features": [
    {
      "id": "browser-bookmarks",
      "name": "手动快速链接",
      "desc": "手动收藏、置顶链接、最近使用与快速打开；不读取浏览器书签或历史",
      "icon": {
        "type": "file",
        "value": "assets/logo.svg"
      },
      "keywords": ["bookmark", "bookmarks", "quicklink", "quicklinks", "pinned", "收藏", "置顶", "快速链接", "网址", "链接", "link", "url"],
      "push": true,
      "priority": 7,
      "acceptedInputTypes": ["text"],
      "platform": {
        "win32": true,
        "darwin": true,
        "linux": true
      },
      "commands": [
        {
          "type": "over",
          "value": ["bookmark", "bookmarks", "quicklink", "quicklinks", "收藏", "快速链接", "网址"]
        }
      ]
    }
  ]
}
