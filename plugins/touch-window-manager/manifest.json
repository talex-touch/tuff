{
  "id": "com.tuffex.window-manager",
  "name": "touch-window-manager",
  "version": "1.0.0",
  "author": "TalexTouch Team",
  "sdkapi": 260428,
  "category": "utilities",
  "icon": {
    "type": "file",
    "value": "assets/logo.svg"
  },
  "description": "桌面窗口调度：激活、关闭、贴边、置顶、启动",
  "main": "index.js",
  "permissions": {
    "required": ["system.shell", "search.root-results"],
    "optional": []
  },
  "permissionReasons": {
    "system.shell": "调用系统脚本管理应用窗口",
    "search.root-results": "将窗口管理入口推送到 CoreBox 根搜索结果"
  },
  "searchProviders": [
    {
      "id": "touch-window-manager.window-app",
      "displayName": "窗口管理",
      "featureId": "window-app",
      "kind": "system-action",
      "owner": "official-plugin",
      "mode": "push",
      "priority": "fast",
      "defaultOrder": 92,
      "permissionScopes": ["root-results"],
      "defaultState": "ask",
      "requiresUserConsent": true,
      "pushesToRootResults": true
    }
  ],
  "features": [
    {
      "id": "window-app",
      "name": "窗口管理",
      "desc": "管理桌面应用窗口（Windows/macOS）",
      "icon": {
        "type": "file",
        "value": "assets/logo.svg"
      },
      "keywords": ["window", "app", "应用", "窗口管理", "激活", "关闭", "启动", "贴边", "置顶", "snap", "topmost"],
      "push": true,
      "priority": 6,
      "acceptedInputTypes": ["text"],
      "platform": {
        "win32": true,
        "darwin": true,
        "linux": false
      },
      "commands": [
        {
          "type": "over",
          "value": ["window", "app", "应用", "窗口管理"]
        }
      ]
    }
  ]
}
