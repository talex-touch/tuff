{
  "id": "com.tuffex.browser-data",
  "name": "touch-browser-data",
  "version": "1.0.0",
  "author": "TalexTouch Team",
  "sdkapi": 260428,
  "category": "utilities",
  "icon": {
    "type": "emoji",
    "value": "🌐"
  },
  "description": "浏览器数据：只读搜索 Chrome、Edge、Brave、Arc 的本地书签",
  "main": "index.js",
  "permissions": {
    "required": ["fs.read", "search.root-results"],
    "optional": ["clipboard.write", "network.internet"]
  },
  "permissionReasons": {
    "fs.read": "只读扫描本机浏览器 Bookmarks JSON 文件用于搜索书签",
    "search.root-results": "将匹配到的浏览器书签推送到 CoreBox 根搜索结果",
    "clipboard.write": "复制书签 URL 到剪贴板",
    "network.internet": "使用默认浏览器打开本地浏览器书签 URL"
  },
  "searchProviders": [
    {
      "id": "touch-browser-data.browser-bookmarks",
      "displayName": "浏览器书签",
      "kind": "browser-bookmark",
      "owner": "official-plugin",
      "mode": "push",
      "priority": "fast",
      "defaultOrder": 60,
      "permissionScopes": ["root-results", "browser-data"],
      "defaultState": "ask",
      "requiresUserConsent": true,
      "pushesToRootResults": true,
      "indexedSourceId": "browser-bookmarks"
    }
  ],
  "features": [
    {
      "id": "browser-data",
      "name": "浏览器数据",
      "desc": "只读搜索本机浏览器书签",
      "icon": {
        "type": "emoji",
        "value": "🌐"
      },
      "keywords": ["browser-data", "browser", "chrome", "edge", "brave", "arc", "bookmarks", "浏览器", "书签"],
      "push": true,
      "priority": 8,
      "acceptedInputTypes": ["text"],
      "platform": {
        "win32": true,
        "darwin": true,
        "linux": true
      },
      "commands": [
        {
          "type": "over",
          "value": ["browser-data", "browser", "chrome", "edge", "brave", "arc", "bookmarks", "浏览器", "书签"]
        }
      ]
    }
  ]
}
