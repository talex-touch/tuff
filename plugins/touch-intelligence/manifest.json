{
  "id": "com.tuffex.intelligence",
  "name": "touch-intelligence",
  "version": "1.2.0",
  "author": "TalexTouch Team",
  "sdkapi": 260713,
  "category": "ai",
  "icon": {
    "type": "file",
    "value": "assets/logo.svg"
  },
  "description": "CoreBox 智能问答、内置 AI 命令与本地自定义命令注册表",
  "main": "index.js",
  "dev": {
    "enable": true,
    "source": true,
    "address": "http://127.0.0.1:5174/"
  },
  "build": {
    "index": {
      "entry": "index.js",
      "format": "cjs",
      "target": "node24",
      "external": ["electron"],
      "minify": true,
      "sourcemap": false
    }
  },
  "permissions": {
    "required": ["intelligence.basic", "search.root-results"],
    "optional": ["clipboard.write"]
  },
  "permissionReasons": {
    "intelligence.basic": "调用智能能力完成问答",
    "clipboard.write": "复制 AI 回答或将回答替换到当前应用的选中文本",
    "search.root-results": "将智能问答入口与回答状态推送到 CoreBox 根搜索结果"
  },
  "searchProviders": [
    {
      "id": "touch-intelligence.intelligence-ask",
      "displayName": "智能问答",
      "featureId": "intelligence-ask",
      "kind": "ai",
      "owner": "official-plugin",
      "mode": "push",
      "priority": "fast",
      "defaultOrder": 106,
      "permissionScopes": ["root-results"],
      "defaultState": "ask",
      "requiresUserConsent": true,
      "pushesToRootResults": true
    }
  ],
  "features": [
    {
      "id": "intelligence-ask",
      "name": "智能问答",
      "desc": "使用 ai/@ai 前缀在 CoreBox 里调用 AI 回答，支持图片 OCR",
      "icon": {
        "type": "file",
        "value": "assets/logo.svg"
      },
      "keywords": ["ai", "@ai", "/ai", "智能", "问答", "chat", "助手"],
      "push": true,
      "priority": 200,
      "acceptedInputTypes": ["text", "image"],
      "interaction": {
        "type": "widget",
        "path": "ask-panel",
        "showInput": true,
        "allowInput": true,
        "sendMode": true,
        "forceMax": true
      },
      "platform": {
        "win32": true,
        "darwin": true,
        "linux": true
      },
      "commands": [
        {
          "type": "match",
          "value": ["ai", "@ai", "/ai", "智能", "问答"]
        }
      ]
    },
    {
      "id": "intelligence-rewrite",
      "name": "AI 改写",
      "desc": "无历史地改写当前文本，只返回改写结果",
      "icon": {
        "type": "file",
        "value": "assets/logo.svg"
      },
      "keywords": ["rewrite", "改写", "润色", "ai"],
      "push": true,
      "priority": 195,
      "acceptedInputTypes": ["text"],
      "interaction": {
        "type": "widget",
        "path": "ask-panel",
        "showInput": true,
        "allowInput": true,
        "sendMode": true,
        "forceMax": true
      },
      "platform": {
        "win32": true,
        "darwin": true,
        "linux": true
      },
      "commands": [{ "type": "match", "value": ["rewrite", "改写"] }]
    },
    {
      "id": "intelligence-summarize",
      "name": "AI 摘要",
      "desc": "无历史地提炼当前文本，只返回简洁摘要",
      "icon": {
        "type": "file",
        "value": "assets/logo.svg"
      },
      "keywords": ["summarize", "summary", "总结", "摘要", "ai"],
      "push": true,
      "priority": 194,
      "acceptedInputTypes": ["text"],
      "interaction": {
        "type": "widget",
        "path": "ask-panel",
        "showInput": true,
        "allowInput": true,
        "sendMode": true,
        "forceMax": true
      },
      "platform": {
        "win32": true,
        "darwin": true,
        "linux": true
      },
      "commands": [
        { "type": "match", "value": ["summarize", "summary", "总结", "摘要"] }
      ]
    },
    {
      "id": "intelligence-explain",
      "name": "AI 解释",
      "desc": "无历史地解释当前文本，只返回解释结果",
      "icon": {
        "type": "file",
        "value": "assets/logo.svg"
      },
      "keywords": ["explain", "解释", "说明", "ai"],
      "push": true,
      "priority": 193,
      "acceptedInputTypes": ["text"],
      "interaction": {
        "type": "widget",
        "path": "ask-panel",
        "showInput": true,
        "allowInput": true,
        "sendMode": true,
        "forceMax": true
      },
      "platform": {
        "win32": true,
        "darwin": true,
        "linux": true
      },
      "commands": [{ "type": "match", "value": ["explain", "解释"] }]
    },
    {
      "id": "intelligence-command-registry",
      "name": "AI 命令管理",
      "desc": "查看、重新加载并打开本地自定义 AI 命令配置",
      "icon": {
        "type": "file",
        "value": "assets/logo.svg"
      },
      "keywords": ["ai commands", "AI 命令", "命令管理", "registry"],
      "push": true,
      "priority": 192,
      "acceptedInputTypes": ["text"],
      "interaction": {
        "type": "widget",
        "path": "command-registry",
        "showInput": false,
        "allowInput": false,
        "sendMode": false,
        "forceMax": true
      },
      "platform": {
        "win32": true,
        "darwin": true,
        "linux": true
      },
      "commands": [
        {
          "type": "match",
          "value": ["ai commands", "AI命令", "AI 命令", "命令管理"]
        }
      ]
    }
  ]
}
