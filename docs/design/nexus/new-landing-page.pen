                  "fill": "$white",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Can we switch between Free, Plus, Pro, and Team at any time?",
                  "lineHeight": 1.35,
                  "fontFamily": "Space Grotesk",
                  "fontSize": 18,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "h44PW",
                  "name": "faqA1",
                  "fill": "$gray-500",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Yes. Upgrades are immediate and prorated. Downgrades apply at the next billing cycle, and no data is deleted automatically.",
