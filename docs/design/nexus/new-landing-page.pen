                    {
                      "type": "text",
                      "id": "Wvdl9",
                      "name": "secP1",
                      "fill": "#A1A1AA",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The Channel module uses Electron IPC under the hood, with two distinct types: MAIN for renderer communication and PLUGIN for isolated plugin messaging.",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
