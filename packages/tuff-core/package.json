{
  "name": "@talex-touch/tuff-core",
  "type": "module",
  "version": "0.0.1",
  "description": "Low-level build and publish primitives for Tuff",
  "license": "MIT",
  "keywords": [
    "tuff",
    "core"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --splitting --clean --target node24 --platform node",
    "dev": "tsup src/index.ts --format esm --dts --splitting --clean --target node24 --platform node --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
