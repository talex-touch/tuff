{
  "name": "@talex-touch/tuff-native",
  "version": "1.0.0",
  "private": true,
  "description": "Native OCR bindings for Talex Touch",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./ocr": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./everything": {
      "types": "./everything.d.ts",
      "require": "./everything.js",
      "default": "./everything.js"
    },
    "./everything-resources": {
      "types": "./everything-resources.d.ts",
      "require": "./everything-resources.js",
      "default": "./everything-resources.js"
    },
    "./screenshot": {
      "types": "./screenshot.d.ts",
      "require": "./screenshot.js",
      "default": "./screenshot.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "native-loader.js",
    "binding.gyp",
    "scripts/build-screenshot.js",
    "native/src",
    "native-screenshot",
    "build/Release/*.node",
    "everything.js",
    "everything.d.ts",
    "everything-resources.js",
    "everything-resources.d.ts",
    "screenshot.js",
    "screenshot.d.ts",
    "native/src/everything/addon.cc"
  ],
  "gypfile": true,
  "scripts": {
    "build": "node-gyp rebuild",
    "build:screenshot": "node scripts/build-screenshot.js",
    "rebuild": "node-gyp rebuild",
    "check:everything": "node scripts/everything-selfcheck.js"
  },
  "dependencies": {
    "node-addon-api": "^7.1.1"
  },
  "devDependencies": {
    "node-gyp": "^11.5.0"
  }
}
