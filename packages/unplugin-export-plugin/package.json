{
  "name": "@talex-touch/unplugin-export-plugin",
  "type": "module",
  "version": "1.2.16",
  "description": "Export unplugin for talex-touch",
  "license": "MIT",
  "homepage": "https://github.com/talex-touch/unplugin-export-plugin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talex-touch/unplugin-export-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/talex-touch/unplugin-export-plugin/issues"
  },
  "keywords": [
    "unplugin",
    "vite",
    "webpack",
    "rollup",
    "tuff",
    "talex-tuff"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "import": "./dist/rollup.js"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.js"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.ts",
      "import": "./dist/nuxt.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "node ../../node_modules/eslint/bin/eslint.js --cache \"src/**/*.{ts,tsx}\"",
    "lint:fix": "node ../../node_modules/eslint/bin/eslint.js --cache --fix \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "npm run build",
    "release": "bumpp && npm publish --access public"
  },
  "peerDependencies": {
    "chalk": "^5.6.0",
    "debug": "^4.3.5",
    "esbuild": "^0.25.0 || ^0.28.0",
    "fs-extra": "^11.3.1",
    "pathe": "^1.1.2",
    "unplugin": "^1.16.1 || ^2.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@types/debug": "^4.1.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^18.19.130",
    "bumpp": "^11.1.0",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
