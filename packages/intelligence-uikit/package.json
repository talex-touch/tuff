{
  "name": "@talex-touch/intelligence-uikit",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "AI scenario UI kit for Tuff intelligence experiences.",
  "author": "TalexDreamSoul",
  "license": "MIT",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./style.css": "./src/style/index.scss"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3405",
    "mockup": "vite --host 127.0.0.1 --port 3405",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" --fix",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.5.27"
  },
  "dependencies": {
    "@talex-touch/tuff-intelligence": "workspace:*",
    "@talex-touch/tuffex": "workspace:*",
    "@talex-touch/utils": "workspace:*"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "eslint": "catalog:dev",
    "typescript": "catalog:dev",
    "vite": "^7.3.6",
    "vitest": "^3.2.7",
    "vue-tsc": "catalog:dev"
  }
}
