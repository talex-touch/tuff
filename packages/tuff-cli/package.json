    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vue/compiler-sfc": "3.5.39",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "compressing": "^1.10.5",
    "debug": "^4.4.3",
    "esbuild": "^0.28.1",
    "fs-extra": "^11.3.6",
    "glob": "^10.5.0",
    "pathe": "^1.1.2",
    "unplugin": "^2.3.11",
    "vite": "^7.3.6"
  },
  "devDependencies": {
    "@talex-touch/tuff-cli-core": "workspace:*",
    "@talex-touch/unplugin-export-plugin": "workspace:*",
    "eslint": "^9.39.4",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.1",
