{
  "name": "@talex-touch/tuff-cli",
  "type": "module",
  "version": "0.0.7",
  "description": "Tuff CLI entrypoint",
  "license": "MIT",
  "keywords": [
    "tuff",
    "cli"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tuff": "bin/tuff.js"
  },
  "files": [
    "bin",
    "dist"
  ],
