{
  "name": "@talex-touch/tuffex",
  "version": "0.3.5",
  "author": "TalexDreamSoul<TalexDreamSoul@gmail.com>",
  "description": "TuffEx - Modern Vue3 component library with beautiful animations and tactile experience.",
  "keywords": [
    "tuff",
    "tuffex",
    "talex-touch",
    "vue3",
    "components",
    "ui-library",
    "animation",
    "tactile",
    "glassmorphism"
  ],
  "type": "module",
  "main": "dist/lib/index.js",
  "module": "dist/es/index.js",
  "types": "dist/es/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/es/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/lib/index.js"
    },
    "./style.css": "./dist/es/components.css",
    "./utils": {
      "types": "./dist/es/utils/index.d.ts",
      "import": "./dist/es/utils/index.js",
      "require": "./dist/lib/utils/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "node --loader ts-node/esm ./node_modules/gulp/bin/gulp.js -f packages/script/build/index.ts",
    "build:vite": "vite build",
    "component:create": "esno ./utils/create/index.ts",
    "comp:create": "esno ./utils/createComponent/index.ts",
    "dev": "vitepress dev docs --port 8000--host",
    "lint": "pnpm exec eslint --cache .",
    "lint:fix": "pnpm exec eslint --cache --fix .",
    "docs:dev": "vitepress dev docs --port 8000 --host",
    "docs:new": "esno ./utils/createVitepressComp/index.ts",
    "docs:build": "vitepress build docs"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.5.27"
  },
  "dependencies": {
    "@better-scroll/core": "^2.5.1",
    "@better-scroll/pull-down": "^2.5.1",
    "@better-scroll/pull-up": "^2.5.1",
    "@better-scroll/scroll-bar": "^2.5.1",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@floating-ui/vue": "^1.1.11",
    "@number-flow/vue": "^0.5.0",
    "@vueuse/core": "^14.2.1",
    "dompurify": "^3.4.1",
    "gsap": "catalog:",
    "marked": "^12.0.2",
    "v-wave": "^3.0.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.20",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.80",
    "@types/gulp": "^4.0.18",
    "@types/gulp-autoprefixer": "^0.0.37",
    "@types/gulp-sass": "^5.0.4",
    "@types/node": "^22.19.15",
    "@vitejs/plugin-vue": "^6.0.6",
    "chalk": "^5.6.2",
    "dotenv": "^16.6.1",
    "esno": "^4.8.0",
    "gulp": "^5.0.1",
    "gulp-autoprefixer": "^9.0.0",
    "gulp-sass": "^5.1.0",
    "sass": "catalog:",
    "search-insights": "^2.17.3",
    "sucrase": "^3.35.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "unocss": "^66.6.8",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vue": "^3.5.33"
  }
}
