{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "paths": {
      "@tuffex/*": ["./*"],
      "@talex-touch/tuffex": ["./packages/components/src/index.ts"],
      "@talex-touch/tuffex/style.css": ["./packages/components/style/index.scss"],
      "@talex-touch/tuffex/base.css": ["./packages/components/style/index.scss"],
      "@talex-touch/tuffex/*/style.css": ["./packages/components/src/*/style/index.scss"],
      "@talex-touch/tuffex/utils": ["./packages/utils/index.ts"],
      "@talex-touch/tuffex/*": ["./packages/components/src/*/index.ts"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.d.ts",
    "packages/**/*.vue"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "**/node_modules",
    "**/__tests__/**"
  ]
}
