{
  "name": "@talex-touch/tuff-cli-core",
  "type": "module",
  "version": "0.0.1",
  "description": "Core APIs for Tuff CLI",
  "license": "MIT",
  "keywords": [
    "tuff",
    "cli",
    "core"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@talex-touch/utils": "workspace:*",
    "chalk": "^5.6.0",
    "cli-progress": "^3.12.0",
    "compressing": "^1.10.3",
    "esbuild": "^0.24.0",
    "fs-extra": "^11.3.1",
    "glob": "^10.5.0",
    "pathe": "^1.1.2",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/node": "^18.19.130",
    "eslint": "^9.39.4",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
