# Canonical file: apps/pilot/deploy/deploy-pilot-1panel-webhook.env.example

PILOT_WEBHOOK_TOKEN=replace-with-random-token
PILOT_WEBHOOK_ALLOWED_BRANCH=master
PILOT_WEBHOOK_ALLOWED_REPOSITORY=talex-touch/tuff

