# Canonical file: apps/pilot/deploy/deploy-pilot-1panel.env.example
# Optional. If omitted, script will auto-detect compose under cwd and /opt/1panel.
PILOT_PROJECT_DIR=
PILOT_COMPOSE_FILE=docker-compose.yml
PILOT_SERVICE_NAME=pilot

PILOT_IMAGE_REPO=ghcr.io/talex-touch/tuff-pilot
PILOT_IMAGE_TAG=pilot-latest

# Optional bootstrap controls for first deployment when compose file does not exist.
PILOT_BOOTSTRAP_COMPOSE=false
PILOT_BOOTSTRAP_HTTP_PORT=3300
PILOT_DB_DRIVER=sqlite
PILOT_DB_FILE=/app/data/pilot.sqlite
PILOT_POSTGRES_URL=
PILOT_REDIS_URL=redis://redis:6379/0
PILOT_PG_DB=pilot
PILOT_PG_USER=pilot
PILOT_PG_PASSWORD=pilot_change_me

PILOT_HEALTHCHECK_URL=http://127.0.0.1:3300/api/auth/status
PILOT_HEALTHCHECK_ATTEMPTS=20
PILOT_HEALTHCHECK_INTERVAL_SEC=3
PILOT_ROLLBACK_ON_FAILURE=true

PILOT_GHCR_USERNAME=
PILOT_GHCR_TOKEN=
