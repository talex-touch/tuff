# Canonical file: apps/pilot/deploy/deploy-pilot-1panel.env.example

PILOT_IMAGE_TAG=pilot-latest

PILOT_POSTGRES_URL=postgresql://pilot:pilot_change_me@postgres:5432/pilot
PILOT_REDIS_URL=redis://redis:6379/0
PILOT_JWT_ACCESS_SECRET=replace-with-access-secret-min-16
PILOT_JWT_REFRESH_SECRET=replace-with-refresh-secret-min-16
PILOT_COOKIE_SECRET=replace-with-cookie-secret-min-16
PILOT_CONFIG_ENCRYPTION_KEY=replace-with-config-encryption-key-min-16
PILOT_BOOTSTRAP_ADMIN_EMAIL=admin@pilot.local
PILOT_BOOTSTRAP_ADMIN_PASSWORD=admin

PILOT_EXECUTOR_DEBUG=0
NUXT_PUBLIC_NEXUS_ORIGIN=
PILOT_NEXUS_OAUTH_CLIENT_ID=
PILOT_NEXUS_OAUTH_CLIENT_SECRET=

PILOT_HEALTHCHECK_URL=http://127.0.0.1:3300/api/auth/status
PILOT_HEALTHCHECK_ATTEMPTS=20
PILOT_HEALTHCHECK_INTERVAL_SEC=3
PILOT_ROLLBACK_ON_FAILURE=true
