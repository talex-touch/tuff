{
  "name": "@talex-touch/tuff",
  "type": "module",
  "version": "2.4.9-beta.4",
  "packageManager": "pnpm@10.32.1",
  "description": "A strong adaptation more platform all-tool program.",
  "author": "TalexDreamSoul <TalexDreamSoul@Gmail.com>",
  "license": "MPL-2.0 license",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "network:guard": "node scripts/check-network-boundaries.mjs",
    "compat:registry:guard": "node scripts/check-compatibility-debt-registry.mjs",
    "size:guard": "node scripts/check-large-file-boundaries.mjs",
    "legacy:guard": "node scripts/check-legacy-boundaries.mjs && pnpm compat:registry:guard && pnpm size:guard",
    "guard:global-app": "node scripts/check-main-global-app-usage.mjs",
    "test:targeted": "pnpm -C \"packages/utils\" exec vitest run \"__tests__/plugin-sdk-lifecycle.test.ts\" \"__tests__/transport-domain-sdks.test.ts\" \"__tests__/transport/port-policy.test.ts\" && pnpm -C \"apps/core-app\" exec vitest run \"src/renderer/src/modules/auth/sync-preferences.test.ts\" \"src/main/modules/plugin/plugin-loaders.test.ts\" \"src/main/channel/common.test.ts\" && pnpm -C \"apps/nexus\" exec vitest run \"server/api/sync/__tests__/sync-routes-410.test.ts\"",
    "test:core-main": "pnpm -C \"apps/core-app\" run test:core-main && pnpm -C \"apps/core-app\" run typecheck:node && pnpm guard:global-app",
    "quality:gate": "pnpm legacy:guard && pnpm network:guard && pnpm test:targeted && pnpm -C \"apps/core-app\" run typecheck:node && pnpm -C \"apps/core-app\" run typecheck:web && pnpm docs:guard",
    "lint": "pnpm -r --filter \"./apps/core-app\" --filter \"./apps/nexus\" --filter \"./apps/pilot\" --filter \"./packages/*\" --filter \"./plugins/*\" exec eslint --cache --no-warn-ignored \"**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}\" && pnpm intelligence:check && pnpm legacy:guard",
    "lint:fix": "pnpm -r --filter \"./apps/core-app\" --filter \"./apps/nexus\" --filter \"./apps/pilot\" --filter \"./packages/*\" --filter \"./plugins/*\" exec eslint --cache --fix --no-warn-ignored \"**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}\" && pnpm intelligence:check && pnpm legacy:guard",
    "lint:staged": "lint-staged",
    "prepare": "husky install",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node scripts/sync-core-package.mjs",
    "typecheck": "pnpm -F @talex-touch/core-app run typecheck",
    "typecheck:all": "pnpm -r --if-present run typecheck",
    "sync:core-pkg": "node scripts/sync-core-package.mjs",
    "core:dev": "pnpm -F @talex-touch/core-app run dev",
    "nexus:dev": "pnpm -F @talex-touch/tuff-nexus run dev",
    "pilot:dev": "pnpm -F @talex-touch/tuff-pilot run dev",
    "pilot:build": "pnpm -F @talex-touch/tuff-pilot run build",
    "pilot:typecheck": "pnpm -F @talex-touch/tuff-pilot run typecheck",
    "pilot:lint": "pnpm -F @talex-touch/tuff-pilot run lint",
    "nexus:content:reset": "pnpm -F @talex-touch/tuff-nexus run content:reset",
    "build": "pnpm -F @talex-touch/core-app run build",
    "build:beta": "pnpm -F @talex-touch/core-app run build:beta",
    "build:snapshot": "pnpm -F @talex-touch/core-app run build:snapshot",
    "build:release": "pnpm -F @talex-touch/core-app run build:release",
    "build:snapshot:win": "pnpm -F @talex-touch/core-app run build:snapshot:win",
    "build:snapshot:mac": "pnpm -F @talex-touch/core-app run build:snapshot:mac",
    "build:snapshot:linux": "pnpm -F @talex-touch/core-app run build:snapshot:linux",
    "build:release:win": "pnpm -F @talex-touch/core-app run build:release:win",
    "build:release:mac": "pnpm -F @talex-touch/core-app run build:release:mac",
    "build:release:linux": "pnpm -F @talex-touch/core-app run build:release:linux",
    "utils:test": "pnpm -F test run test",
    "utils:publish": "pnpm -F @talex-touch/utils run publish",
    "tuffex:dev": "pnpm -F @talex-touch/tuffex run docs:dev",
    "tuffex:build": "pnpm -F @talex-touch/tuffex run build",
    "tuffex:docs": "pnpm -F @talex-touch/tuffex run docs:build",
    "unplugin:build": "pnpm -F @talex-touch/unplugin-export-plugin run build",
    "unplugin:publish": "pnpm -F @talex-touch/unplugin-export-plugin run release",
    "version": "node scripts/version-sync.mjs",
    "version:patch": "node scripts/version-sync.mjs --patch",
    "version:minor": "node scripts/version-sync.mjs --minor",
    "version:major": "node scripts/version-sync.mjs --major",
    "plugins:validate": "node scripts/validate-plugins.mjs",
    "intelligence:check": "node scripts/check-intelligence-no-todo.mjs",
    "docs:guard": "node scripts/check-doc-governance.mjs",
    "docs:guard:strict": "node scripts/check-doc-governance.mjs --strict true"
  },
  "dependencies": {
    "@sentry/vite-plugin": "^4.9.1",
    "electron": "^41.0.2",
    "vite-plugin-electron": "^0.29.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@typescript-eslint/parser": "^8.57.0",
    "bumpp": "^10.4.1",
    "chalk": "^5.6.2",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "volta": {
    "node": "22.16.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@compodoc/compodoc",
      "@nestjs/core",
      "@parcel/watcher",
      "@sentry/cli",
      "@swc/core",
      "@talex-touch/tuff-native",
      "browser-tabs-lock",
      "bufferutil",
      "core-js",
      "electron",
      "electron-clipboard-ex",
      "electron-winstaller",
      "esbuild",
      "extract-file-icon",
      "get-windows",
      "msgpackr-extract",
      "puppeteer",
      "sharp",
      "simple-git-hooks",
      "tesseract.js",
      "typeit",
      "uiohook-napi",
      "unrs-resolver",
      "utf-8-validate",
      "vue-demi",
      "workerd"
    ],
    "overrides": {
      "@nuxt/devtools": "catalog:build",
      "@nuxt/kit": "catalog:build",
      "@panva/hkdf": "1.0.2",
      "@types/node": "24.1.0",
      "fast-xml-parser": "4.5.4",
      "nuxt": "catalog:build",
      "unplugin": "catalog:build",
      "vite": "7.3.1"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "next",
        "react",
        "react-dom"
      ],
      "allowedVersions": {
        "citty": "^0.1.6 || ^0.2.0",
        "commander": "^13.1.0 || ^14.0.0",
        "nodemailer": "^6.6.5 || ^7.0.0",
        "vue-tsc": "^2.1.10 || ^3.2.5"
      }
    }
  },
  "lint-staged": {
    "apps/core-app/**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}": [
      "pnpm -C \"apps/core-app\" exec eslint --cache --fix --no-warn-ignored"
    ],
    "apps/nexus/**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}": [
      "pnpm -C \"apps/nexus\" exec eslint --cache --fix --max-warnings=0 --no-warn-ignored"
    ],
    "packages/test/**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}": [
      "pnpm -C \"packages/test\" exec eslint --cache --fix --max-warnings=0 --no-warn-ignored"
    ],
    "packages/tuff-intelligence/**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}": [
      "pnpm -C \"packages/tuff-intelligence\" exec eslint --cache --fix --max-warnings=0 --no-warn-ignored"
    ],
    "packages/tuffex/**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}": [
      "pnpm -C \"packages/tuffex\" exec eslint --cache --fix --max-warnings=0 --no-warn-ignored"
    ],
    "packages/unplugin-export-plugin/**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}": [
      "pnpm -w exec eslint --cache --fix --max-warnings=0 --no-warn-ignored --config \"packages/unplugin-export-plugin/eslint.config.js\""
    ],
    "packages/utils/**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}": [
      "pnpm -C \"packages/utils\" exec eslint --cache --fix --max-warnings=0 --no-warn-ignored"
    ],
    "plugins/touch-image/**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}": [
      "pnpm -C \"plugins/touch-image\" exec eslint --cache --fix --max-warnings=0 --no-warn-ignored"
    ],
    "plugins/touch-music/**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}": [
      "pnpm -C \"plugins/touch-music\" exec eslint --cache --fix --max-warnings=0 --no-warn-ignored"
    ],
    "plugins/touch-translation/**/*.{js,jsx,ts,tsx,vue,mjs,cjs,cts,mts}": [
      "pnpm -C \"plugins/touch-translation\" exec eslint --cache --fix --max-warnings=0 --no-warn-ignored"
    ],
    "scripts/**/*.{js,jsx,ts,tsx,mjs,cjs,cts,mts}": [
      "eslint --cache --fix --max-warnings=0 --no-warn-ignored"
    ]
  }
}
