{
  "name": "@talex-touch/core-app",
  "version": "2.4.13-beta.15",
  "private": true,
  "description": "A strong adaptation more platform all-tool program.",
  "author": "TalexDreamSoul <TalexDreamSoul@Gmail.com>",
  "license": "MPL-2.0 license",
  "homepage": "https://tuff.tagzxia.com",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache . --quiet",
    "lint:fix": "eslint --cache --fix .",
    "test": "vitest run",
    "test:core-main": "vitest run \"src/main/core\" \"src/main/channel\" \"src/main/modules/tray\"",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "corepack pnpm -F @talex-touch/tuffex run build && vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "corepack pnpm run typecheck:node && corepack pnpm run typecheck:web",
    "test:omnipanel": "vitest run src/main/modules/omni-panel/index.test.ts src/renderer/src/views/omni-panel/filter-features.test.ts src/renderer/src/views/omni-panel/interaction.test.ts",
    "test:shortcut-lifecycle": "vitest run src/main/modules/global-shortcon.test.ts src/main/modules/division-box/shortcut-trigger.test.ts src/main/modules/omni-panel/index.test.ts",
    "smoke:omnipanel": "cross-env TUFF_OMNIPANEL_SMOKE=1 electron-vite preview",
    "smoke:plugin-view-preload": "electron scripts/plugin-view-preload-smoke.cjs",
    "start": "electron-vite preview",
    "dev": "node scripts/dev-electron-wrapper.mjs",
    "build": "pnpm run typecheck && electron-vite build",
    "build:vite": "electron-vite build",
    "postinstall": "echo 'Skipping electron-builder install-app-deps - will run during build'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:beta": "node scripts/build-target.js --target=${BUILD_TARGET:-mac} --type=beta",
    "build:beta:win": "node scripts/build-target.js --target=win --type=beta",
    "build:beta:mac": "node scripts/build-target.js --target=mac --type=beta",
    "build:beta:linux": "node scripts/build-target.js --target=linux --type=beta",
    "build:snapshot": "node scripts/build-target.js --target=${BUILD_TARGET:-mac} --type=snapshot",
    "build:release": "node scripts/build-target.js --target=${BUILD_TARGET:-mac} --type=release",
    "build:win": "node scripts/build-target.js --target=win --type=release",
    "build:mac": "node scripts/build-target.js --target=mac --type=release",
    "build:linux": "node scripts/build-target.js --target=linux --type=release",
    "build:snapshot:win": "node scripts/build-target.js --target=win --type=snapshot",
    "build:snapshot:mac": "node scripts/build-target.js --target=mac --type=snapshot",
    "build:snapshot:linux": "node scripts/build-target.js --target=linux --type=snapshot",
    "build:release:win": "node scripts/build-target.js --target=win --type=release",
    "build:release:mac": "node scripts/build-target.js --target=mac --type=release",
    "build:release:linux": "node scripts/build-target.js --target=linux --type=release",
    "perf:bundle:size": "node scripts/bundle-size-report.mjs",
    "startup:bench:dev": "node \"scripts/startup-benchmark-dev.mjs\" --mode run --runs 30 --continueOnFail",
    "startup:bench:packaged:hot": "node \"scripts/startup-benchmark-dev.mjs\" --target packaged --profile hot --mode run --runs 10 --continueOnFail",
    "startup:bench:packaged:cold": "node \"scripts/startup-benchmark-dev.mjs\" --target packaged --profile cold --mode run --runs 10 --continueOnFail",
    "startup:bench:analyze": "node \"scripts/startup-benchmark-dev.mjs\" --mode analyze",
    "visible:experience:template": "corepack pnpm exec tsx \"scripts/coreapp-visible-experience-template.ts\"",
    "visible:experience:verify": "corepack pnpm exec tsx \"scripts/coreapp-visible-experience-verify.ts\"",
    "visible:experience:readiness": "corepack pnpm exec tsx \"scripts/coreapp-visible-experience-readiness.ts\"",
    "visible:experience:ai-ask-probe": "corepack pnpm exec tsx \"scripts/coreapp-packaged-ai-ask-probe.ts\"",
    "visible:experience:app-index-workbench-probe": "corepack pnpm exec tsx \"scripts/coreapp-visible-app-index-workbench-probe.ts\"",
    "visible:experience:assistant-floating-ball-probe": "corepack pnpm exec tsx \"scripts/coreapp-visible-assistant-floating-ball-probe.ts\"",
    "visible:experience:assistant-image-translate-probe": "corepack pnpm exec tsx \"scripts/coreapp-visible-assistant-image-translate-probe.ts\"",
    "visible:experience:workflow-review-queue-probe": "corepack pnpm exec tsx \"scripts/coreapp-visible-workflow-review-queue-probe.ts\"",
    "visible:experience:login-recovery-probe": "corepack pnpm exec tsx \"scripts/coreapp-packaged-login-recovery-probe.ts\"",
    "visible:experience:indexing-diagnostics-probe": "corepack pnpm exec tsx \"scripts/coreapp-packaged-indexing-diagnostics-probe.ts\"",
    "visible:experience:indexing-diagnostics-attach": "corepack pnpm exec tsx \"scripts/coreapp-packaged-indexing-diagnostics-probe.ts\" -- --attachOnly",
    "smoke:assistant": "pnpm exec tsx \"scripts/assistant-floating-ball-smoke.ts\"",
    "clipboard:stress": "pnpm exec tsx \"scripts/clipboard-polling-stress.ts\"",
    "clipboard:stress:verify": "pnpm exec tsx \"scripts/clipboard-stress-verify.ts\"",
    "app-index:diagnostic:verify": "pnpm exec tsx \"scripts/app-index-diagnostic-verify.ts\"",
    "everything:diagnostic:verify": "pnpm exec tsx \"scripts/everything-diagnostic-verify.ts\"",
    "settings:indexing-diagnostics:verify": "pnpm exec tsx \"scripts/settings-indexing-diagnostics-verify.ts\"",
    "search:fts-ownership-simulate": "pnpm exec tsx \"scripts/search-index-fts-ownership-simulation.ts\"",
    "search:index-migration:preflight": "pnpm exec tsx \"scripts/search-index-migration-preflight.ts\"",
    "search:index-migration:evidence-verify": "pnpm exec tsx \"scripts/search-index-migration-evidence-verify.ts\"",
    "search:production-migration-readiness": "pnpm exec tsx \"scripts/search-index-production-migration-readiness.ts\"",
    "search:scan-progress-simulate": "pnpm exec tsx \"scripts/scan-progress-source-scope-simulation.ts\"",
    "search:scan-progress-migration": "pnpm exec tsx \"scripts/scan-progress-source-scope-migration.ts\"",
    "update:diagnostic:verify": "pnpm exec tsx \"scripts/update-diagnostic-verify.ts\"",
    "search:trace:stats": "pnpm exec tsx \"scripts/search-trace-stats.ts\"",
    "search:trace:verify": "pnpm exec tsx \"scripts/search-trace-verify.ts\"",
    "windows:capability:evidence": "pnpm exec tsx \"scripts/windows-capability-evidence.ts\"",
    "windows:capability:verify": "pnpm exec tsx \"scripts/windows-capability-verify.ts\"",
    "windows:acceptance:template": "pnpm exec tsx \"scripts/windows-acceptance-template.ts\"",
    "windows:acceptance:verify": "pnpm exec tsx \"scripts/windows-acceptance-verify.ts\"",
    "quickops:surface:audit": "pnpm exec tsx \"scripts/quickops-surface-audit.ts\"",
    "quickops:flow-ai:audit": "pnpm exec tsx \"scripts/quickops-flow-ai-adapter-audit.ts\"",
    "quickops:evidence:template": "pnpm exec tsx \"scripts/quickops-evidence-template.ts\"",
    "quickops:evidence:verify": "pnpm exec tsx \"scripts/quickops-evidence-verify.ts\"",
    "context:entrypoint:evidence:verify": "pnpm exec tsx \"scripts/context-entrypoint-evidence.ts\""
  },
  "dependencies": {
    "@arrow-js/core": "1.0.6",
    "@earendil-works/pi-agent-core": "0.80.10",
    "@earendil-works/pi-ai": "0.80.10",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fingerprintjs/fingerprintjs": "^4.6.2",
    "@langchain/anthropic": "^0.3.34",
    "@langchain/core": "^0.3.80",
    "@langchain/langgraph": "^0.4.9",
    "@langchain/openai": "^0.4.9",
    "@libsql/client": "^0.17.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/electron": "^7.15.0",
    "@talex-touch/tuff-business": "workspace:^",
    "@talex-touch/tuff-intelligence": "workspace:^",
    "@talex-touch/tuff-native": "workspace:^",
    "@talex-touch/tuffex": "workspace:^",
