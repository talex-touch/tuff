    "@vue/compiler-sfc": "^3.5.39",
    "chokidar": "^4.0.3",
    "compressing": "^2.1.1",
    "dayjs": "^1.11.21",
    "detect-libc": "^2.1.2",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.1",
    "extract-file-icon": "^0.3.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fs-extra": "^11.3.6",
    "fuse.js": "^7.4.2",
    "iconv-lite": "^0.7.3",
    "log4js": "^6.9.1",
    "mathjs": "^15.2.0",
    "ms": "^2.1.3",
    "original-fs": "^1.2.0",
    "pinyin-pro": "^3.28.1",
    "sharp": "^0.34.5",
    "simple-plist": "1.4.0",
    "talex-mica-electron": "^1.0.2",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "optionalDependencies": {
    "@crosscopy/clipboard": "^0.3.6",
