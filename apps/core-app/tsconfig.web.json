{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/renderer/src/*"],
      "~/assets/*": ["src/renderer/src/assets/*"],
      "~/components/*": ["src/renderer/src/components/*"],
      "~/views/*": ["src/renderer/src/views/*"],
      "~/store/*": ["src/renderer/src/store/*"],
      "~/plugins/*": ["src/renderer/src/plugins/*"],
      "~/utils/*": ["src/renderer/src/utils/*"],
      "~/types/*": ["src/renderer/src/types/*"],
      "~/modules/*": ["src/renderer/src/modules/*"],
      "@talex-touch/tuff-business": ["../../packages/tuff-business/src/index.ts"],
      "@talex-touch/tuff-intelligence": ["../../packages/tuff-intelligence/src/index.ts"],
      "@talex-touch/tuff-intelligence/*": ["../../packages/tuff-intelligence/src/*"],
      "@talex-touch/tuffex": ["../../packages/tuffex/packages/components/src/index.ts"],
      "@talex-touch/tuffex/base.css": ["../../packages/tuffex/packages/components/style/index.scss"],
      "@talex-touch/tuffex/*/style.css": ["../../packages/tuffex/dist/es/*/style.css"],
      "@talex-touch/tuffex/utils": ["../../packages/tuffex/packages/utils/index.ts"],
      "@talex-touch/tuffex/*": ["../../packages/tuffex/packages/components/src/*/index.ts"]
    }
  },
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.vue",
    "src/shared/**/*.ts",
    "src/preload/*.d.ts",
    "src/renderer/auto-imports.d.ts",
    "src/renderer/components.d.ts",
    "../../packages/tuff-business/src/**/*.ts",
    "../../packages/tuff-business/src/**/*.vue",
    "../../packages/tuff-intelligence/src/**/*.ts",
    "../../packages/tuffex/packages/components/src/**/*.ts",
    "../../packages/tuffex/packages/components/src/**/*.vue",
    "../../packages/tuffex/packages/utils/**/*.ts"
  ],
  "exclude": [
    "../../packages/tuff-business/src/**/__tests__/**",
    "../../packages/tuff-intelligence/src/**/__tests__/**",
    "../../packages/tuffex/packages/components/src/**/__tests__/**",
    "../../packages/tuffex/packages/utils/**/__tests__/**"
  ]
}
