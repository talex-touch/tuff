{
  "name": "@talex-touch/tuff-nexus",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "description": "Documentation for Tuff project",
  "imports": {
    "#auth": "./node_modules/@sidebase/nuxt-auth/dist/runtime/server/services/index.js",
    "#auth/*": "./node_modules/@sidebase/nuxt-auth/dist/runtime/server/services/*.js"
  },
  "scripts": {
    "build": "pnpm -C \"../../packages/tuffex\" run build && node -e \"const os=require('os'); const v8=require('v8'); const gb=n=> (n/1024/1024/1024).toFixed(2); console.log('[build] totalmem_gb', gb(os.totalmem())); console.log('[build] heap_limit_gb', gb(v8.getHeapStatistics().heap_size_limit));\" && NODE_OPTIONS=\"--max-old-space-size=8192\" nuxt build && node build/trim-content-assets.mjs",
    "check:api-routes": "node build/check-server-api-route-tree.mjs",
    "check:runtime-evidence": "node build/check-runtime-evidence.mjs",
    "check:runtime-evidence:deployed": "node build/check-runtime-evidence.mjs --require-deployed-preview",
    "check:runtime-evidence:template": "node build/check-runtime-evidence.mjs --print-deployed-preview-template",
    "collect:runtime-evidence:deployed": "node scripts/collect-deployed-preview-evidence.mjs",
    "build:analyze-worker": "node build/check-worker-bundle.mjs",
    "dev:pwa": "VITE_PLUGIN_PWA=true nuxt dev",
    "dev": "NUXT_USE_CLOUDFLARE_DEV=true CLOUDFLARE_DEV_ENVIRONMENT=preview nuxt dev --port 3200",
    "dev:pure": "nuxt dev --port 3200 --host 127.0.0.1",
    "dev:cf": "NUXT_USE_CLOUDFLARE_DEV=true CLOUDFLARE_DEV_ENVIRONMENT=preview nuxt dev --port 3200",
    "content:reset": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('.data/content', { recursive: true, force: true })\"",
    "generate": "nuxt generate",
    "prepare": "nuxt prepare",
    "preview": "nuxt preview",
    "preview:cf": "pnpm build && npx wrangler pages dev dist --compatibility-date=2024-08-14 --binding AUTH_ORIGIN=${AUTH_ORIGIN:-http://127.0.0.1:8788} --binding AUTH_SECRET=${AUTH_SECRET:-tuff-local-pages-preview-secret} --binding APP_AUTH_JWT_SECRET=${APP_AUTH_JWT_SECRET:-tuff-local-app-auth-jwt-secret} --binding NUXT_INTELLIGENCE_ENCRYPT_KEY=${NUXT_INTELLIGENCE_ENCRYPT_KEY:-tuff-local-intelligence-encrypt-key}",
    "deploy:cf": "pnpm build && npx wrangler pages deploy dist",
    "start": "node .output/server/index.mjs",
    "start:generate": "npx serve .output/public",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "visual:smoke:tuffex": "node scripts/tuffex-visual-smoke.mjs",
    "openapi:sync": "openapi-typescript ./openapi/nexus-sync.yaml -o ./types/sync-api.d.ts",
    "dev:host": "nuxt dev --port 3200 --host 0.0.0.0"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@floating-ui/vue": "catalog:",
    "@iconify-json/cib": "catalog:",
    "@langchain/anthropic": "^0.3.34",
    "@langchain/core": "^0.3.80",
    "@langchain/langgraph": "^0.4.9",
    "@langchain/openai": "^0.4.9",
    "@sentry/nuxt": "catalog:",
    "@sidebase/nuxt-auth": "^1.3.1",
    "@talex-touch/intelligence-uikit": "workspace:*",
    "@talex-touch/tuff-business": "workspace:*",
    "@talex-touch/tuff-intelligence": "workspace:*",
    "@talex-touch/tuffex": "workspace:*",
    "@talex-touch/utils": "workspace:*",
    "echarts": "^6.1.0",
    "fighting-design": "catalog:",
    "gsap": "catalog:",
    "jszip": "catalog:",
    "mermaid": "catalog:",
    "ogl": "catalog:",
    "simplex-noise": "catalog:",
    "theme-colors": "^0.1.0",
    "typeit": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@cloudflare/workers-types": "catalog:dev",
    "@iconify-json/carbon": "catalog:icons",
    "@iconify-json/twemoji": "catalog:icons",
    "@nuxt/content": "catalog:build",
    "@nuxt/devtools": "catalog:build",
    "@nuxt/eslint": "catalog:build",
    "@nuxtjs/color-mode": "catalog:build",
    "@nuxtjs/i18n": "catalog:build",
    "@pinia/nuxt": "catalog:build",
    "@unocss/eslint-config": "catalog:build",
    "@unocss/nuxt": "catalog:build",
    "@unocss/preset-typography": "catalog:build",
    "@vite-pwa/nuxt": "catalog:build",
    "@vueuse/core": "^14.3.0",
    "baseline-browser-mapping": "catalog:dev",
    "better-sqlite3": "^12.11.1",
    "eslint": "catalog:dev",
    "eslint-plugin-format": "catalog:dev",
    "next-auth": "~4.24.14",
    "nitro-cloudflare-dev": "catalog:dev",
    "nuxt": "catalog:build",
    "openapi-typescript": "^7.13.0",
    "pinia": "^3.0.4",
    "sass": "catalog:",
    "typescript": "catalog:dev",
    "unocss": "catalog:build",
    "vitepress": "catalog:",
    "vue": "^3.5.39",
    "vue-tsc": "catalog:dev",
    "webpack": "catalog:dev",
    "wrangler": "catalog:dev"
  }
}
