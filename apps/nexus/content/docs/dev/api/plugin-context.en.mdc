## recommend

RecommendSDK for registering custom recommendation providers with CoreBox.

:::TuffCodeBlock{lang="javascript"}
---
code: |
  // Register recommendation provider
  const dispose = recommend.registerProvider({
  id: 'my-recommendation',
  name: 'My Recommendations',
  canProvide(context) {
  return context.timeOfDay === 'morning'
  },
  getCandidates(context) {
  return [{
  id: 'morning-tip',
  title: 'Morning Reminder',
  subtitle: 'Start a new day',
  icon: { type: 'emoji', value: '☀️' },
  priority: 75,
  action: 'show-morning-tip'
  }]
  }
  })

  // Unregister provider
  dispose()
  // or
  recommend.unregisterProvider('my-recommendation')
---
:::

> See [RecommendSDK API](./recommend.en.md) for full documentation.

