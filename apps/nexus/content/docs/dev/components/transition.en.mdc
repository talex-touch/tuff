              <TuffSelectItem value="fade" label="fade" />
              <TuffSelectItem value="slide-fade" label="slide-fade" />
              <TuffSelectItem value="rebound" label="rebound" />
            </TuffSelect>
          </label>

          <TxButton size="small" @click="add">
            Add
          </TxButton>
