::TuffPropsTable
---
rows:
  - name: modelValue
    type: 'boolean'
    default: 'false'
    description: '开关值'
  - name: size
    type: "'small' | 'default' | 'large'"
    default: "'default'"
    description: '尺寸'
  - name: disabled
    type: 'boolean'
