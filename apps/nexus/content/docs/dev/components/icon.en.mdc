    type: 'string'
    default: '-'
    description: 'Icon name or class'
  - name: size
    type: 'number'
    default: '16'
    description: 'Icon size'
  - name: colorful
    type: 'boolean'
    default: 'false'
    description: 'Keep original colors'
  - name: urlResolver
    type: "(url: string, type: 'url' | 'file') => string"
    default: '-'
    description: 'Override URL/file path resolution'
  - name: svgFetcher
    type: '(url: string) => Promise<string>'
    default: '-'
    description: 'Override SVG content fetching'
---
::

