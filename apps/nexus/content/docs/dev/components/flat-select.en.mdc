  const value = ref('')
  </script>

  <template>
    <!-- Group disabled -->
    <TxFlatSelect v-model="value" placeholder="Select" disabled>
      <TxFlatSelectItem value="a" label="Option A" />
      <TxFlatSelectItem value="b" label="Option B" />
