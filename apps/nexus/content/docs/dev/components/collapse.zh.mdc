  <script setup lang="ts">
  import { ref } from 'vue'

  const active = ref(['first'])
  </script>

  <template>
    <TxCollapse v-model="active">
      <TxCollapseItem title="快速开始" name="first">
        这里是基础说明。
      </TxCollapseItem>
      <TxCollapseItem title="高级选项" name="second">
        这里是高级配置说明。
      </TxCollapseItem>
    </TxCollapse>
