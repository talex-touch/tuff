### Closable

Use closable tags for removable filters or user-defined labels.

:::TuffDemoWrapper{demo="TagClosableDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import { ref } from 'vue'

  const tags = ref(['Design', 'Docs', 'Pending'])
  function removeTag(tag: string) {
    tags.value = tags.value.filter(item => item !== tag)
  }
  </script>

  <template>
    <TxTag v-for="tag in tags" :key="tag" :label="tag" closable @close="removeTag(tag)" />
  </template>
---
:::

