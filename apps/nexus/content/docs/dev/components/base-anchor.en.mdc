  import { ref } from 'vue'

  const open = ref(false)
  </script>

  <template>
    <TxBaseAnchor
      v-model="open"
      placement="bottom-start"
      :show-arrow="true"
    >
      <template #reference>
        <TxButton>Soft Edge</TxButton>
      </template>

      <div style="width: 240px; padding: 4px;">
        Content emerges with a soft gradient edge.
      </div>
    </TxBaseAnchor>
  </template>
---
:::

## Placement

Content enters and exits from the placement direction. For `top`, content slides down from above and returns upward on close.

