  const value = ref<TxRadioValue>('focus')
  </script>

  <template>
    <TxRadioGroup v-model="value" indicator-variant="glass">
      <TxRadio value="focus">专注</TxRadio>
      <TxRadio value="review">复盘</TxRadio>
