# Select

`TuffSelect` renders a Popover-backed dropdown for primitive `string | number` values. It defaults to single select, and `multiple` switches it to array values with tag rendering. Options can be declared with `TuffSelectItem` or passed directly through `options`; the dropdown supports local filtering, remote search, loading / empty states, grouping, inline creation, and custom footer content.

## Basic Selection

Use the default mode for compact form fields and filters. The trigger is read-only, opens on click, and displays the selected item label after an enabled option is picked.

### Select
:::TuffDemoWrapper{demo="SelectSelectDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('engineering')
  </script>

  <template>
    <TuffSelect v-model="value" placeholder="Please select">
      <TuffSelectItem value="design" label="Design team" />
      <TuffSelectItem value="engineering" label="Engineering team" />
      <TuffSelectItem value="support" label="Support team" />
    </TuffSelect>
  </template>
---
:::

## Local Filtering

Set `searchable` when all options are already available locally. The search input is rendered inside the dropdown panel and filters registered option labels.

### Select (searchable)
:::TuffDemoWrapper{demo="SelectSelectSearchableDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('docs')
  </script>

  <template>
    <TuffSelect
      v-model="value"
      placeholder="Search workspace"
      search-placeholder="Type a tag name"
      searchable
    >
      <TuffSelectItem value="docs" label="Docs" />
      <TuffSelectItem value="sdk" label="SDK tools" />
      <TuffSelectItem value="release" label="Release" />
    </TuffSelect>
  </template>
---
:::

## Remote Search

Use `remote` with `editable` when option data comes from a remote source. The trigger becomes an editable input, opens on focus, and emits `search` while the dropdown is open. Use `loading` / `loadingText`, or the `loading` slot, for remote pending feedback.

### Select (remote searchable)
:::TuffDemoWrapper{demo="SelectSelectRemoteSearchableDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('agent-builder')
  const sourceOptions = [
    { value: 'agent-builder', label: 'Agent Builder' },
    { value: 'flow-runner', label: 'Flow Runner' },
  ]
  const options = ref(sourceOptions)

  function onSearch(query: string) {
    // Replace this local filter with a debounced remote request.
    options.value = sourceOptions.filter(option =>
      option.label.toLowerCase().includes(query.toLowerCase()),
    )
  }
  </script>

  <template>
    <TuffSelect
      v-model="value"
      remote
      editable
      placeholder="Search remote capability"
      :options="options"
      :loading="false"
      loading-text="Loading..."
      @search="onSearch"
    />
  </template>
---
:::

## Multiple Tags

Set `multiple` to make `v-model` an `Array<string | number>`. The trigger renders selected values as removable tags. Clicking an option toggles it and keeps the dropdown open.

### Select (multiple tags)
:::TuffDemoWrapper{demo="SelectSelectMultipleTagsDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue[]>(['a1', 'b2'])
  const options = [
    { value: 'a1', label: 'a1' },
    { value: 'b2', label: 'b2' },
    { value: 'c3', label: 'c3' },
  ]
  </script>

  <template>
    <TuffSelect
      v-model="value"
      multiple
      :options="options"
      :max-tag-count="2"
      placeholder="Select tags"
    />
  </template>
---
:::

## Inline Creation

Combine `multiple`, `searchable`, and `allowCreate` for user-created tags. Press Enter or click the default footer action to create `{ value, label }` from the current input. Persist created options by appending them to your own `options` source in the `create` handler.

### Select (allow create)
:::TuffDemoWrapper{demo="SelectSelectAllowCreateDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectOption, TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue[]>(['agent'])
  const options = ref<TxSelectOption[]>([
    { value: 'agent', label: 'agent' },
    { value: 'workflow', label: 'workflow' },
  ])

  function onCreate(option: TxSelectOption) {
    options.value = [...options.value, option]
  }
  </script>

  <template>
    <TuffSelect
      v-model="value"
      multiple
      searchable
      allow-create
      create-text="Add tag"
      placeholder="Type or select tags"
      :options="options"
      @create="onCreate"
    />
  </template>
---
:::

## Groups and Footer

`options` supports grouped entries shaped as `{ label, options }`. Use the `footer` slot for add buttons, helper copy, or shortcut actions at the bottom of the dropdown.

### Select (grouped with footer)
:::TuffDemoWrapper{demo="SelectSelectGroupedFooterDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('lucy')
  const options = [
    {
      label: 'Manager',
      options: [
        { value: 'jack', label: 'Jack' },
        { value: 'lucy', label: 'Lucy' },
      ],
    },
    {
      label: 'Engineer',
      options: [
        { value: 'yiminghe', label: 'Yiminghe' },
      ],
    },
  ]
  </script>

  <template>
    <TuffSelect v-model="value" :options="options" placeholder="Select member">
      <template #footer>
        <button type="button" style="padding: 6px 10px;">
          + Add member
        </button>
      </template>
    </TuffSelect>
  </template>
---
:::

## Status Border

Use `status="error"` or `status="warning"` for validation state. Status only controls the visual border; validation messages should still live in the form item or host UI.

### Select (status)
:::TuffDemoWrapper{demo="SelectSelectStatusDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const errorValue = ref<TxSelectValue>('')
  const warningValue = ref<TxSelectValue>('')
  const options = [
    { value: 'stable', label: 'Stable' },
    { value: 'beta', label: 'Beta' },
  ]
  </script>

  <template>
    <div style="display: grid; gap: 12px;">
      <TuffSelect v-model="errorValue" status="error" :options="options" placeholder="Error status" />
      <TuffSelect v-model="warningValue" status="warning" :options="options" placeholder="Warning status" />
    </div>
  </template>
---
:::

