# Select

`TuffSelect` renders a Popover-backed dropdown for one primitive `string | number` value. Options are registered by `TuffSelectItem`, selected labels mirror into the trigger input, disabled options stay visible, and editable remote mode emits search queries from the trigger.

## Basic Selection

Use the default mode for compact form fields and filters. The trigger is read-only, opens on click, and displays the selected item label after an enabled option is picked.

### Select
:::TuffDemoWrapper{demo="SelectSelectDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('engineering')
  </script>

  <template>
    <TuffSelect v-model="value" placeholder="Please select">
      <TuffSelectItem value="design" label="Design team" />
      <TuffSelectItem value="engineering" label="Engineering team" />
      <TuffSelectItem value="support" label="Support team" />
    </TuffSelect>
  </template>
---
:::

## Local Filtering

Set `searchable` when all options are already available locally. The search input is rendered inside the dropdown panel and filters registered option labels.

### Select (searchable)
:::TuffDemoWrapper{demo="SelectSelectSearchableDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('docs')
  </script>

  <template>
    <TuffSelect
      v-model="value"
      placeholder="Search workspace"
      search-placeholder="Type a tag name"
      searchable
    >
      <TuffSelectItem value="docs" label="Docs" />
      <TuffSelectItem value="sdk" label="SDK tools" />
      <TuffSelectItem value="release" label="Release" />
    </TuffSelect>
  </template>
---
:::

## Remote Search

Use `remote` with `editable` when option data comes from a remote source. The trigger becomes an editable input, opens on focus, and emits `search` while the dropdown is open.

### Select (remote searchable)
:::TuffDemoWrapper{demo="SelectSelectRemoteSearchableDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('agent-builder')
  const sourceOptions = [
    { value: 'agent-builder', label: 'Agent Builder' },
    { value: 'flow-runner', label: 'Flow Runner' },
  ]
  const options = ref(sourceOptions)

  function onSearch(query: string) {
    // Replace this local filter with a debounced remote request.
    options.value = sourceOptions.filter(option =>
      option.label.toLowerCase().includes(query.toLowerCase()),
    )
  }
  </script>

  <template>
    <TuffSelect v-model="value" remote editable placeholder="Search remote capability" @search="onSearch">
      <TuffSelectItem v-for="option in options" :key="option.value" :value="option.value" :label="option.label" />
    </TuffSelect>
  </template>
---
:::

