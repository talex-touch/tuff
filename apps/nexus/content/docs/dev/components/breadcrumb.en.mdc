code: |
  <script setup lang="ts">
  const items = [
    { label: 'Home', href: '/', icon: 'i-carbon-home' },
    { label: 'Library' },
    { label: 'Data' },
  ]

  function onBreadcrumbClick(item: { label: string }, index: number) {
    console.log(item.label, index)
  }
  </script>

  <template>
    <TxBreadcrumb :items="items" @click="onBreadcrumbClick" />
  </template>
