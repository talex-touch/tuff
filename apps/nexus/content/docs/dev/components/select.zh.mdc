# Select 选择器

`TuffSelect` 用于选择 `string | number` 原始值。默认是单选，也可以通过 `multiple` 切换为数组值和标签返显。选项既可以用 `TuffSelectItem` 声明，也可以通过 `options` 直接传入；下拉面板支持本地过滤、远程搜索、loading / empty 状态、分组、自助创建与自定义 footer。

## 基础选择

默认模式适合紧凑表单和筛选器。触发器只读，点击展开，选择启用项后展示当前选项 label。

### Select
:::TuffDemoWrapper{demo="SelectSelectDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('engineering')
  </script>

  <template>
    <TuffSelect v-model="value" placeholder="请选择">
      <TuffSelectItem value="design" label="设计团队" />
      <TuffSelectItem value="engineering" label="工程团队" />
      <TuffSelectItem value="support" label="支持团队" />
    </TuffSelect>
  </template>
---
:::

## 本地过滤

当所有选项已在本地可用时使用 `searchable`。搜索框渲染在下拉面板内，并根据已注册选项 label 进行过滤。

### Select (searchable)
:::TuffDemoWrapper{demo="SelectSelectSearchableDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('docs')
  </script>

  <template>
    <TuffSelect
      v-model="value"
      placeholder="搜索工作区"
      search-placeholder="输入标签名称"
      searchable
    >
      <TuffSelectItem value="docs" label="Docs 文档" />
      <TuffSelectItem value="sdk" label="SDK 工具" />
      <TuffSelectItem value="release" label="Release 发布" />
    </TuffSelect>
  </template>
---
:::

## 远程搜索

选项来自远程数据源时，组合使用 `remote` 与 `editable`。触发器会变成可编辑输入框，聚焦后展开，并在面板打开期间发出 `search`。如果需要 loading 文案，可传 `loading` / `loadingText`，或使用 `loading` slot 自定义。

### Select (remote searchable)
:::TuffDemoWrapper{demo="SelectSelectRemoteSearchableDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('agent-builder')
  const sourceOptions = [
    { value: 'agent-builder', label: 'Agent Builder' },
    { value: 'flow-runner', label: 'Flow Runner' },
  ]
  const options = ref(sourceOptions)

  function onSearch(query: string) {
    // 实际项目里替换为 debounce 后的远程请求。
    options.value = sourceOptions.filter(option =>
      option.label.toLowerCase().includes(query.toLowerCase()),
    )
  }
  </script>

  <template>
    <TuffSelect
      v-model="value"
      remote
      editable
      placeholder="搜索远程能力"
      :options="options"
      :loading="false"
      loading-text="加载中..."
      @search="onSearch"
    />
  </template>
---
:::

## 多选标签

设置 `multiple` 后，`v-model` 使用 `Array<string | number>`，触发器会以标签形式返显选中项。点击标签关闭按钮可删除；点击选项会 toggle 选中状态，不会关闭面板。

### Select (multiple tags)
:::TuffDemoWrapper{demo="SelectSelectMultipleTagsDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue[]>(['a1', 'b2'])
  const options = [
    { value: 'a1', label: 'a1' },
    { value: 'b2', label: 'b2' },
    { value: 'c3', label: 'c3' },
  ]
  </script>

  <template>
    <TuffSelect
      v-model="value"
      multiple
      :options="options"
      :max-tag-count="2"
      placeholder="选择标签"
    />
  </template>
---
:::

## 自助创建

多选场景下可组合 `multiple`、`searchable` 与 `allowCreate`。输入新内容后按 Enter，或点击默认 footer 中的添加按钮，会触发 `create` 并把新值加入当前选择。业务侧如果需要持久化新选项，应在 `create` 回调中追加到自己的 `options` 数据源。

### Select (allow create)
:::TuffDemoWrapper{demo="SelectSelectAllowCreateDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectOption, TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue[]>(['agent'])
  const options = ref<TxSelectOption[]>([
    { value: 'agent', label: 'agent' },
    { value: 'workflow', label: 'workflow' },
  ])

  function onCreate(option: TxSelectOption) {
    options.value = [...options.value, option]
  }
  </script>

  <template>
    <TuffSelect
      v-model="value"
      multiple
      searchable
      allow-create
      create-text="添加标签"
      placeholder="输入或选择标签"
      :options="options"
      @create="onCreate"
    />
  </template>
---
:::

## 分组与自定义下拉

`options` 支持分组对象：`{ label, options }`。使用 `footer` slot 可自定义下拉底部内容，适合添加按钮、说明或快捷操作。

### Select (grouped with footer)
:::TuffDemoWrapper{demo="SelectSelectGroupedFooterDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('lucy')
  const options = [
    {
      label: 'Manager',
      options: [
        { value: 'jack', label: 'Jack' },
        { value: 'lucy', label: 'Lucy' },
      ],
    },
    {
      label: 'Engineer',
      options: [
        { value: 'yiminghe', label: 'Yiminghe' },
      ],
    },
  ]
  </script>

  <template>
    <TuffSelect v-model="value" :options="options" placeholder="选择成员">
      <template #footer>
        <button type="button" style="padding: 6px 10px;">
          + 添加成员
        </button>
      </template>
    </TuffSelect>
  </template>
---
:::

## 状态边框

使用 `status="error"` 或 `status="warning"` 可标记校验状态。状态只负责视觉提示，校验文案仍建议放在表单项或业务说明中。

### Select (status)
:::TuffDemoWrapper{demo="SelectSelectStatusDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const errorValue = ref<TxSelectValue>('')
  const warningValue = ref<TxSelectValue>('')
  const options = [
    { value: 'stable', label: '稳定' },
    { value: 'beta', label: 'Beta' },
  ]
  </script>

  <template>
    <div style="display: grid; gap: 12px;">
      <TuffSelect v-model="errorValue" status="error" :options="options" placeholder="错误状态" />
      <TuffSelect v-model="warningValue" status="warning" :options="options" placeholder="警告状态" />
    </div>
  </template>
---
:::

