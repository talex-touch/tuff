code: |
  <script setup lang="ts">
  import type { TxSelectValue } from '@talex-touch/tuffex'
  import { ref } from 'vue'

  const value = ref<TxSelectValue>('locked')
  </script>

  <template>
    <TuffSelect v-model="value" placeholder="禁用状态" disabled eager>
