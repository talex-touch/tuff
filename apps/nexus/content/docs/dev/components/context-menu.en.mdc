# ContextMenu

`TxContextMenu` is a general menu overlay. It can bind to the native `contextmenu` event and open from controlled coordinates. Positioning, collision handling, Card surface, and motion are now hosted by `TxBaseAnchor` through virtual-anchor mode, so the menu follows the latest position when users right-click repeatedly. The visual/content part is also available as `TxContextMenuPanel`, so the same menu items can be embedded inside `TxPopover` or any custom overlay.

## Basic and Composition Scenarios

### ContextMenu
:::TuffDemoWrapper{demo="ContextMenuContextMenuDemo" code-lang="vue"}
---
code: |
  <script setup lang="ts">
  import { computed, ref } from 'vue'

  const controlledOpen = ref(false)
  const x = ref(0)
  const y = ref(0)
  const clickOpen = ref(false)
  const clickX = ref(0)
  const clickY = ref(0)
  const popoverOpen = ref(false)
  const animationMode = ref<'transfer' | 'boom' | 'opacity' | 'none'>('transfer')
  const lastAction = ref('Waiting for action')

  const animationOptions = computed(() => ({
    type: animationMode.value,
    duration: animationMode.value === 'none' ? 0 : 180,
    closeDuration: animationMode.value === 'none' ? 0 : 120,
    distance: 12,
    scale: 0.94,
    blur: 8,
  }))

  function setAction(action: string) {
    lastAction.value = action
  }

  function openAtCenter() {
    x.value = Math.round(window.innerWidth * 0.5)
    y.value = Math.round(window.innerHeight * 0.38)
    controlledOpen.value = true
  }

  function openClickMenu(event: MouseEvent) {
    const rect = (event.currentTarget as HTMLElement).getBoundingClientRect()
    clickX.value = Math.round(rect.left + rect.width / 2)
    clickY.value = Math.round(rect.bottom + 8)
    clickOpen.value = true
  }
  </script>

  <template>
    <div style="display: grid; gap: 14px; width: min(100%, 680px);">
      <div style="display: flex; flex-wrap: wrap; gap: 8px; align-items: center;">
        <TxButton type="primary" @click="openAtCenter">
          Open controlled menu
        </TxButton>
        <TxButton @click="controlledOpen = false; clickOpen = false">
          Close
        </TxButton>
      </div>

      <!-- Controlled coordinates: useful for command palettes, editors, custom shortcuts, and canvas nodes. -->
      <TxContextMenu
        v-model="controlledOpen"
        :x="x"
        :y="y"
        :animation="animationOptions"
        show-arrow
      >
        <template #menu>
          <TxContextMenuItem shortcut="⌘C" @select="setAction('Copy')">
            Copy
          </TxContextMenuItem>
          <TxContextMenuItem shortcut="⌘V" disabled>
            Paste disabled
          </TxContextMenuItem>
          <TxContextMenuDivider />
          <TxContextMenuItem color="#8b5cf6" shortcut="⌘K">
            Custom purple action
          </TxContextMenuItem>
          <TxContextMenuItem danger shortcut="⌫">
            Delete
          </TxContextMenuItem>
        </template>
      </TxContextMenu>

      <!-- Uncontrolled right-click: every contextmenu event refreshes coordinates and placement. -->
      <TxContextMenu :animation="animationOptions" :width="260">
        <template #trigger>
          <div style="padding: 24px; border: 1px dashed var(--tx-border-color); border-radius: 14px; user-select: none;">
            Right-click here: the menu avoids edges and follows the latest click position.
          </div>
        </template>

        <template #menu>
          <TxContextMenuItem shortcut="⌘R">Refresh</TxContextMenuItem>
          <TxContextMenuItem shortcut="↩">Rename</TxContextMenuItem>
          <TxContextMenuDivider dashed />
          <TxPopover v-model="popoverOpen" placement="right-start" :close-on-click-outside="false" :show-arrow="false">
            <template #reference>
              <TxContextMenuItem submenu :close-on-select="false" @select="popoverOpen = true">
                More actions
